# ─── Portal da Transparência ──────────────────────────────────────────────────
TRANSPARENCIA_API_KEY=sua_chave_aqui

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=beneficios
POSTGRES_PASSWORD=beneficios_pass
POSTGRES_DB=beneficios_db

# ─── MinIO (Data Lake local S3-compatível) ────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ─── Airflow ──────────────────────────────────────────────────────────────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=gere_uma_chave_fernet_aqui
AIRFLOW_SECRET_KEY=gere_uma_secret_key_aqui
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_EMAIL=seu@email.com
